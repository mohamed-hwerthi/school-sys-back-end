.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
.springBeans
.sts4-cache
*.suo
*.ntvs*
*.njsproj
*.sln

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# Logs
*.log
logs/

