school-system-back/build/

# ─── Frontend (React / Vite) ───
school-system-front/node_modules/
school-system-front/dist/
school-system-front/dist-ssr/
school-system-front/*.local

# ─── Docker ───
docker-data/
postgres-data/

# ─── Misc ───
*.bak
*.tmp
*.temp
